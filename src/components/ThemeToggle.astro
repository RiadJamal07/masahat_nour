---
/**
 * Two-state theme toggle (light ↔ dark).
 *
 * Light is the default for every visitor. Clicking the toggle flips to
 * dark and persists the choice in localStorage as `mn-theme`. The OS
 * preference is intentionally ignored — the inline anti-FOUC script in
 * Layout.astro reads only localStorage.
 *
 * Icon visibility is driven entirely by [data-theme-active] on <html>.
 * We do NOT use Tailwind's `dark:` utilities here — they bind to the
 * media query and would fight our manual-only model.
 */
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle group relative inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-ink/15 text-ink transition-colors hover:bg-surface hover:text-on-surface focus-visible:bg-surface focus-visible:text-on-surface"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  <svg
    data-theme-icon="sun"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="h-[18px] w-[18px]"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      clip-rule="evenodd"
      d="M12 2.25a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75ZM7.5 12a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM18.894 6.166a.75.75 0 0 0-1.06-1.06l-1.591 1.59a.75.75 0 1 0 1.06 1.061l1.591-1.59ZM21.75 12a.75.75 0 0 1-.75.75h-2.25a.75.75 0 0 1 0-1.5H21a.75.75 0 0 1 .75.75ZM17.834 18.894a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 1 0-1.061 1.06l1.59 1.591ZM12 18a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-2.25A.75.75 0 0 1 12 18ZM7.758 17.303a.75.75 0 0 0-1.061-1.06l-1.591 1.59a.75.75 0 0 0 1.06 1.061l1.591-1.59ZM6 12a.75.75 0 0 1-.75.75H3a.75.75 0 0 1 0-1.5h2.25A.75.75 0 0 1 6 12ZM6.697 7.757a.75.75 0 0 0 1.06-1.06l-1.59-1.591a.75.75 0 0 0-1.061 1.06l1.59 1.591Z"
    ></path>
  </svg>

  <svg
    data-theme-icon="moon"
    viewBox="0 0 24 24"
    fill="currentColor"
    class="h-[18px] w-[18px]"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      clip-rule="evenodd"
      d="M9.528 1.718a.75.75 0 0 1 .162.819A8.97 8.97 0 0 0 9 6a9 9 0 0 0 9 9 8.97 8.97 0 0 0 3.463-.69.75.75 0 0 1 .981.98 10.503 10.503 0 0 1-9.694 6.46c-5.799 0-10.5-4.7-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 0 1 .818.162Z"
    ></path>
  </svg>
</button>

<style is:global>
  /* Default (no JS yet, no manual override): show sun.
     The script sets [data-theme-active] before the icons matter visually. */
  .theme-toggle [data-theme-icon='moon'] {
    display: none;
  }

  :root[data-theme-active='dark'] .theme-toggle [data-theme-icon='sun'] {
    display: none;
  }
  :root[data-theme-active='dark'] .theme-toggle [data-theme-icon='moon'] {
    display: block;
  }
  :root[data-theme-active='light'] .theme-toggle [data-theme-icon='sun'] {
    display: block;
  }
  :root[data-theme-active='light'] .theme-toggle [data-theme-icon='moon'] {
    display: none;
  }
</style>

<script>
  const STORAGE_KEY = 'mn-theme';
  const root = document.documentElement;

  function resolved(): 'light' | 'dark' {
    return root.dataset.theme === 'dark' ? 'dark' : 'light';
  }

  function syncIcons() {
    root.dataset.themeActive = resolved();
  }

  syncIcons();

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = resolved() === 'dark' ? 'light' : 'dark';
    if (next === 'dark') {
      root.dataset.theme = 'dark';
    } else {
      delete root.dataset.theme;
    }
    localStorage.setItem(STORAGE_KEY, next);
    syncIcons();
  });
</script>
