---
import { Image } from 'astro:assets';
import type { Service } from '~/content/site';

interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
const number = String(index + 1).padStart(2, '0');
---

<details
  id={`service-card-${index}`}
  class="service-card group relative mb-6 flex break-inside-avoid flex-col overflow-hidden rounded-[var(--radius-card)] bg-cream-soft shadow-soft transition-shadow duration-500 open:shadow-md last:mb-0"
>
  <summary
    class="service-card__head flex cursor-pointer list-none flex-col focus-visible:outline-none"
  >
    <div class="relative aspect-[4/3] overflow-hidden">
      <Image
        src={service.image}
        alt={service.name.en}
        widths={[400, 600, 800, 1000]}
        sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
        quality={78}
        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105 group-open:scale-105"
      />
      <span
        class="absolute left-4 top-4 inline-flex h-9 items-center rounded-full bg-cream/90 px-3 text-xs font-medium tracking-widest text-ink uppercase backdrop-blur"
      >
        {number}
      </span>
    </div>

    <div class="flex flex-1 flex-col gap-4 p-6">
      <div class="flex items-start justify-between gap-4">
        <h3 class="text-h3 text-ink">{service.name.en}</h3>
        <div class="text-right">
          <div class="font-display text-2xl leading-none text-teal">
            {service.anchor.price}
          </div>
          <div class="mt-1 text-xs text-ink-soft/70">
            {service.anchor.unit.en}
          </div>
        </div>
      </div>

      <p class="text-sm leading-relaxed text-ink-soft">{service.tagline.en}</p>

      <div
        class="mt-auto flex items-center justify-between gap-3 pt-2 text-xs font-medium tracking-wider text-teal uppercase"
      >
        <span
          lang="ar"
          dir="rtl"
          class="font-arabic text-sm normal-case tracking-normal text-ink-soft/70"
        >
          {service.name.ar}
        </span>
        <span class="service-card__toggle inline-flex items-center gap-1.5">
          <span class="service-card__label-closed">See details</span>
          <span class="service-card__label-open">Hide details</span>
          <svg
            viewBox="0 0 16 16"
            fill="none"
            class="service-card__chevron h-3.5 w-3.5 transition-transform duration-300"
            aria-hidden="true"
          >
            <path
              d="M4 6l4 4 4-4"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </div>
    </div>
  </summary>

  <div class="service-card__body">
    <div class="service-card__body-inner border-t border-ink/8 px-6 py-6">
      <dl class="space-y-4">
        {
          service.tiers.map((tier) => (
            <div class="flex items-baseline justify-between gap-4 border-b border-ink/5 pb-3 last:border-b-0 last:pb-0">
              <div class="min-w-0 flex-1">
                <dt class="text-sm font-medium text-ink">{tier.label.en}</dt>
                {tier.note && (
                  <dd class="mt-1 text-xs leading-relaxed text-ink-soft/70">
                    {tier.note.en}
                  </dd>
                )}
              </div>
              <dd class="shrink-0 text-right">
                <div class="font-display text-lg leading-none text-teal">
                  {tier.price}
                </div>
                <div class="mt-1 text-[11px] text-ink-soft/60">{tier.unit.en}</div>
              </dd>
            </div>
          ))
        }
      </dl>

      {
        service.amenities.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {service.amenities.map((item) => (
              <li class="inline-flex items-center gap-1.5 rounded-full border border-ink/8 bg-cream px-3 py-1.5 text-xs text-ink-soft">
                <span class="h-1 w-1 rounded-full bg-yellow" aria-hidden="true" />
                {item.en}
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</details>
