---
import { Image } from 'astro:assets';
import { site } from '~/content/site';
---

<section id="team" class="container-page py-24 sm:py-32">
  <div class="mb-14 max-w-2xl">
    <p class="text-eyebrow mb-5">{site.team.eyebrow.en}</p>
    <h2 class="text-h1 text-ink">{site.team.title.en}</h2>
    <p class="text-lead mt-6">{site.team.body.en}</p>
  </div>

  <ul class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {
      site.team.members.map((member) => (
        <li class="flex flex-col gap-4">
          <div class="overflow-hidden rounded-[var(--radius-card)]">
            <Image
              src={member.image}
              alt={member.name}
              widths={[320, 480, 640]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              quality={78}
              class="aspect-[4/5] h-full w-full object-cover transition-transform duration-700 hover:scale-[1.03]"
            />
          </div>
          <div>
            <div class="text-base font-medium text-ink">{member.name}</div>
            <div class="mt-0.5 text-xs tracking-wide text-teal uppercase">
              {member.role.en}
            </div>
            <p class="mt-3 text-sm leading-relaxed text-ink-soft/80">
              {member.bio.en}
            </p>
          </div>
        </li>
      ))
    }
  </ul>
</section>
